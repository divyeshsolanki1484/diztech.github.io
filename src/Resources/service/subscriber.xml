<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Zeobv\AbandonedCart\Storefront\Subscriber\PageSubscriber">
            <argument type="service" id="request_stack" />
            <argument type="service" id="zeo_abandoned_cart.repository" />
            <argument type="service" id="Zeobv\AbandonedCart\Service\AbandonedCartService" />
            <argument type="service" id="Zeobv\AbandonedCart\Pagelet\AbandonedCartReminder\Account\AbandonedCartReminderAccountPageletLoader" />
            <argument type="service" id="Zeobv\AbandonedCart\Service\ConfigService" />
            
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Zeobv\AbandonedCart\Core\Subscriber\OrderSubscriber">
            <argument type="service" id="Zeobv\AbandonedCart\Service\AbandonedCartService" />
            <argument type="service" id="order.repository" />
            <argument type="service" id="zeo_abandoned_cart.repository" />

            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
